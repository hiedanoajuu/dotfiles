#!/bin/bash

REPO="$HOME/Projects/dotfiles"
FILES=(
    "$HOME/.zshrc"
    "$HOME/.zshenv"
    "$HOME/.config/alacritty/alacritty.toml"
    "$HOME/.config/nvim/init.lua"
    "$HOME/.gitconfig"
    "$HOME/.config/hypr/hypridle.conf"
    "$HOME/.config/hypr/hyprland.conf"
    "$HOME/.config/hypr/hyprlock.conf"
    "$HOME/.config/hypr/hyprpaper.conf"
)

backup() {
    for i in "${FILES[@]}"; do
        if [ -e "$i" ]; then
            mkdir -p "$REPO/$(dirname "${i#$HOME/}")"
            cp -rf "$i" "$REPO/$(dirname "${i#$HOME/}")/."
        else
            echo "Not found: $item"
        fi
    done

    cd $REPO
    git add .
    git commit -m "$(date '+%Y%m%d%H%M%S')"
    git push
}

restore() {
    cp -rf $REPO/* ~
}

while getopts "vbr" opt; do
    case $opt in
        v) echo "Ajuu Hieda (hieda@ajuu.org)";;
        b) backup;;
        r) restore;;
    esac
done
