{
    "font-family": "Source Sans 3, Noto Sans CJK SC",
    "font-size": 13,
    "font-weight": "normal",

    "layer": "bottom",
    "position": "top",
    "height": 28,
    "spacing": 6,
    "margin": "8px 8px 0px 8px",
    "border-radius": 14,
    "border-color": "rgba(59, 66, 82, 0.9)",
    "background": "rgba(36, 41, 51, 0.85)",

    "modules-left": ["custom/launcher","hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["network", "wireplumber", "battery", "bluetooth", "tray"],

    "hide": {
        "fullscreen": true
    },

    "custom/launcher": {
        "format": "󰣇",
        "tooltip": false,
        "on-click": "wofi --show drun --allow-images --insensitive",
        "on-click-middle": "alacritty -e zsh -c 'fastfetch; read'",
        "on-click-right": "alacritty -e zsh -c 'lf'"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "1": "",
            "2": "",  
            "3": "",
            "4": "",
            "5": ""
        },
    },
    
    "clock": {
        "format": "  {:%H:%M}",
        "tooltip-format": "  {:%Y-%m-%d}\n<tt>{calendar}</tt>",
        "on-click-middle": "qalculate-qt",
        "on-click": "alacritty -e zsh -c 'todo'",
        "on-click-right": "alacritty -e zsh -c 'sdcv'",
        "interval": 30
    },

    "cpu": {
        "format": "  {usage}%",
        "tooltip": false,
        "interval": 2
    },


    "memory": {
        "format": "  {}%",
        "format-alt": "  {used:0.1f}G",
        "interval": 5
    },
    
    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "󰖁",
        "format-icons": ["󰕿", "󰖀", "󰕾"],
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "[ $(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2*100}') -lt 100 ] && wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-",
        "scroll-step": 2
    },
       "network": {
        "format-wifi": "   {essid}",
        "format-ethernet": "  {ifname}",
        "format-disconnected": " ",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-disconnected": "Disconnected",
        "on-click": "iwctl station wlan0 disconnect",
        "interval": 5
    },
        "disk": {
        "format": "  {percentage_used}%",
        "path": "/",
        "interval": 30
    },
    "bluetooth": {
        "format": "󰂯",
        "format-disabled": "󰂲",
        "format-connected": "󰂱",
        "tooltip-format": "Bluetooth",
        "tooltip-format-connected": "{controller_alias}\n{controller_address}\n{device_alias}",
        "on-click": "rfkill toggle bluetooth",
    },
        "battery": {
        "format": "{icon}  {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "format-charging": "  {capacity}%",
        "on-click": "power-menu",
        "on-click-right": "battery-info",
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "interval": 10
    },
    "tray": {
        "spacing": 8
    }
}
